[sub_resource type="GDScript" id="GDScript_meb0d"]
script/source = "extends Node2D
@onready var buttText = $ColorRect/Label
@onready var _links: Array[Control] = [
	$Control/VBoxContainer/auroraLink,
	$Control/VBoxContainer/RobLink,
	$Control/VBoxContainer/joshLink,
]

const _FRUIT_PATHS: Array[String] = [
	\"res://Assets/sprites/fruitSprites/appleSprite.PNG\",
	\"res://Assets/sprites/fruitSprites/bananaSprite.PNG\",
	\"res://Assets/sprites/fruitSprites/blueberrySprite.PNG\",
	\"res://Assets/sprites/fruitSprites/mangoSprite.PNG\",
	\"res://Assets/sprites/fruitSprites/strawberrySprite.PNG\",
]

var _spawn_timer: float = 0.0
var _falling: Array = []

func _ready() -> void:
	for link in _links:
		link.pivot_offset = link.size * 0.5
		link.mouse_entered.connect(_pop_link.bind(link))
		link.mouse_exited.connect(_unpop_link.bind(link))
		link.pressed.connect(func(): AudioManager.play_button_click())

func _pop_link(btn: Control) -> void:
	AudioManager.play_button_hover()
	var tw := btn.create_tween()
	tw.set_trans(Tween.TRANS_BACK)
	tw.set_ease(Tween.EASE_OUT)
	tw.tween_property(btn, \"scale\", Vector2(1.15, 1.15), 0.15)

func _unpop_link(btn: Control) -> void:
	var tw := btn.create_tween()
	tw.set_trans(Tween.TRANS_BACK)
	tw.set_ease(Tween.EASE_OUT)
	tw.tween_property(btn, \"scale\", Vector2(1.0, 1.0), 0.12)

func _process(delta: float) -> void:
	_spawn_timer -= delta
	if _spawn_timer <= 0.0:
		_spawn_fruit()
		_spawn_timer = randf_range(0.5, 1.1)
	var to_remove: Array = []
	for f in _falling:
		if not is_instance_valid(f.node):
			to_remove.append(f)
			continue
		f.node.position.y += f.speed * delta
		f.node.rotation += f.rot_speed * delta
		if f.node.position.y > 1200.0:
			f.node.queue_free()
			to_remove.append(f)
	for f in to_remove:
		_falling.erase(f)

func _spawn_fruit() -> void:
	var path: String = _FRUIT_PATHS[randi() % _FRUIT_PATHS.size()]
	var tex: Texture2D = load(path)
	if tex == null:
		return
	var rect := TextureRect.new()
	rect.texture = tex
	rect.expand_mode = 1
	rect.stretch_mode = 5
	rect.size = Vector2(90, 90)
	rect.z_index = -1
	rect.position = Vector2(randf_range(30.0, 1870.0), -110.0)
	rect.modulate.a = 0.55
	add_child(rect)
	_falling.append({ \"node\": rect, \"speed\": randf_range(160.0, 300.0), \"rot_speed\": randf_range(-1.5, 1.5) })

func _on_button_mouse_entered() -> void:
	AudioManager.play_button_hover()
	buttText.add_theme_color_override(\"font_color\", Color(0.557, 0.514, 0.0))

func _on_button_mouse_exited() -> void:
	buttText.add_theme_color_override(\"font_color\", Color(1, 1, 1, 1))

func _on_button_button_down() -> void:
	AudioManager.play_button_click()
	get_tree().call_group(\"hostController\", \"changeScene\", GameManager.mainMenu)
"

