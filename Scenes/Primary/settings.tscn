[gd_scene format=3 uid="uid://dx8settings01"]

[ext_resource type="Texture2D" uid="uid://bnv5cu7vsqafb" path="res://assets/sprites/backgroundSprite.PNG" id="1_bg"]
[ext_resource type="FontFile" uid="uid://twnwd11gq0wl" path="res://assets/fonts/Magic Yellow by Syaf Rizal [Khurasan™].otf" id="2_font"]

[sub_resource type="GDScript" id="GDScript_settings"]
script/source = "extends Node2D
@onready var buttText = $ColorRect/Label
@onready var music_slider: HSlider = $Control/HSlider
@onready var music_pct: RichTextLabel = $Control/PctLabel
@onready var sfx_slider: HSlider = $Control/SFXSlider
@onready var sfx_pct: RichTextLabel = $Control/SFXPctLabel

var _slider_tick_cooldown: float = 0.0

func _ready() -> void:
	AudioManager.start_menu_music()
	var music_idx := AudioServer.get_bus_index(\"Music\")
	if music_idx != -1:
		var music_db := AudioServer.get_bus_volume_db(music_idx)
		music_slider.value = db_to_linear(music_db) if music_db > -60.0 else 0.0
	_update_pct(music_pct, music_slider.value)
	var sfx_idx := AudioServer.get_bus_index(\"SFX\")
	if sfx_idx != -1:
		var sfx_db := AudioServer.get_bus_volume_db(sfx_idx)
		sfx_slider.value = db_to_linear(sfx_db) if sfx_db > -60.0 else 0.0
	_update_pct(sfx_pct, sfx_slider.value)
	music_slider.mouse_entered.connect(func(): AudioManager.play_button_hover())
	sfx_slider.mouse_entered.connect(func(): AudioManager.play_button_hover())

func _process(delta: float) -> void:
	_slider_tick_cooldown = max(0.0, _slider_tick_cooldown - delta)

func _on_music_slider_changed(value: float) -> void:
	var music_idx := AudioServer.get_bus_index(\"Music\")
	if music_idx != -1:
		AudioServer.set_bus_volume_db(music_idx, linear_to_db(value) if value > 0.0 else -80.0)
	_update_pct(music_pct, value)
	_play_slider_tick(value)

func _on_sfx_slider_changed(value: float) -> void:
	var sfx_idx := AudioServer.get_bus_index(\"SFX\")
	if sfx_idx != -1:
		AudioServer.set_bus_volume_db(sfx_idx, linear_to_db(value) if value > 0.0 else -80.0)
	_update_pct(sfx_pct, value)
	_play_slider_tick(value)

func _play_slider_tick(value: float) -> void:
	if _slider_tick_cooldown > 0.0:
		return
	_slider_tick_cooldown = 0.08
	AudioManager.play_slider_tick(0.7 + value * 0.6)

func _update_pct(label: RichTextLabel, value: float) -> void:
	label.text = \"[center]%d%%[/center]\" % int(round(value * 100.0))

func _on_button_mouse_entered() -> void:
	AudioManager.play_button_hover()
	buttText.add_theme_color_override(\"font_color\", Color(0.557, 0.514, 0.0))

func _on_button_mouse_exited() -> void:
	buttText.add_theme_color_override(\"font_color\", Color(1, 1, 1, 1))

func _on_button_button_down() -> void:
	AudioManager.play_button_click()
	get_tree().call_group(\"hostController\", \"transition_to_scene\", GameManager.mainMenu)
"

