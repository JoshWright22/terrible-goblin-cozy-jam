[sub_resource type="GDScript" id="GDScript_emv3i"]
script/source = "extends Node2D

@onready var menuText = $menuButt/RichTextLabel


func _on_button_button_down() -> void:
	get_tree().call_group(\"hostController\", \"changeScene\", GameManager.mainMenu)
	queue_free()


func _on_button_mouse_entered() -> void: #main enter
	menuText.modulate = Color(0.557, 0.514, 0.0)


func _on_button_mouse_exited() -> void: #main exit
	menuText.modulate = Color(0,0,0,1)
"

